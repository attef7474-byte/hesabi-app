rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signed(){ return request.auth != null; }
    function shopPath(shopId){ return /databases/$(database)/documents/shops/$(shopId); }
    function isAppOwner(){ return signed() && request.auth.token.email == 'attef7474@gmail.com'; }
    function isOwner(shopId){ return signed() && exists(shopPath(shopId)) && get(shopPath(shopId)).data.ownerUid == request.auth.uid; }
    function shopActive(shopId){ return !exists(shopPath(shopId)) || get(shopPath(shopId)).data.subscriptionStatus != 'suspended'; }
    function customerLinkPath(shopId){ return /databases/$(database)/documents/shops/$(shopId)/customerUidLinks/$(request.auth.uid); }
    function hasCustomerLink(shopId){ return signed() && exists(customerLinkPath(shopId)); }
    function linkedCustomerId(shopId){ return get(customerLinkPath(shopId)).data.customerId; }
    function isCustomer(shopId){ return hasCustomerLink(shopId); }
    function isOwnerOrCustomer(shopId){ return isOwner(shopId) || isCustomer(shopId); }
    function isSelfCustomer(){ return signed() && resource.data.customerUid == request.auth.uid; }
    function isLinkedCustomerDoc(shopId){ return hasCustomerLink(shopId) && resource.data.customerId == linkedCustomerId(shopId); }
    function isCustomerOwned(shopId){ return isSelfCustomer() || isLinkedCustomerDoc(shopId); }
    function isNewSelfCustomer(){ return signed() && request.resource.data.customerUid == request.auth.uid; }
    function isNewLinkedCustomerDoc(shopId){ return hasCustomerLink(shopId) && request.resource.data.customerId == linkedCustomerId(shopId); }
    function isNewCustomerOwned(shopId){ return isNewSelfCustomer() || isNewLinkedCustomerDoc(shopId); }
    function isAuthPhone(phoneKey){ return signed() && request.auth.token.email == ('u' + phoneKey + '@hesabi.local'); }
    function canClaimCustomerByPhone(){ return signed() && resource.data.phoneKey is string && isAuthPhone(resource.data.phoneKey); }
    function onlyChanged(keys){ return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys); }

    function requestCustomerMatchesLink(shopId){ return signed() && hasCustomerLink(shopId) && request.resource.data.customerUid == request.auth.uid && request.resource.data.customerId == linkedCustomerId(shopId); }
    function resourceCustomerMatchesLink(shopId){ return signed() && hasCustomerLink(shopId) && resource.data.customerId == linkedCustomerId(shopId) && (resource.data.customerUid == request.auth.uid || !('customerUid' in resource.data)); }

    match /shopPhones/{phoneKey} {
      allow read: if signed();
      allow create: if signed() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if signed() && resource.data.ownerUid == request.auth.uid && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if false;
    }
    match /customerPhoneLinks/{phoneKey}/shops/{shopId} {
      allow read: if signed();
      allow create, update: if signed();
      allow delete: if false;
    }
    match /phoneUidLinks/{phoneKey} {
      allow read: if signed();
      allow create, update: if signed() && request.resource.data.uid == request.auth.uid;
      allow delete: if signed() && resource.data.uid == request.auth.uid;
    }
    match /deviceTokens/{token} {
      allow read: if isAppOwner() || (signed() && resource.data.uid == request.auth.uid);
      allow create, update: if signed() && request.resource.data.uid == request.auth.uid;
      allow delete: if signed() && resource.data.uid == request.auth.uid;
    }
    match /users/{userId} {
      allow read: if isAppOwner() || (signed() && request.auth.uid == userId);
      allow create, update: if signed() && request.auth.uid == userId;
      allow delete: if false;
    }
    match /shops/{shopId} {
      allow read: if isAppOwner() || isOwner(shopId) || hasCustomerLink(shopId) || resource.data.visibility == "public";
      allow create: if signed() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isAppOwner() || isOwner(shopId);
      allow delete: if false;

      match /customerUidLinks/{userId} {
        allow read: if isAppOwner() || isOwner(shopId) || (signed() && request.auth.uid == userId);
        allow create, update: if signed() && request.auth.uid == userId;
        allow delete: if false;
      }
      match /customerPhones/{phoneKey} {
        allow read: if signed();
        allow create, update: if signed();
        allow delete: if false;
      }
      match /items/{id} {
        allow read: if isAppOwner() || isOwner(shopId) || hasCustomerLink(shopId) || (signed() && shopActive(shopId) && get(shopPath(shopId)).data.visibility == "public");
        allow create, update, delete: if isOwner(shopId);
      }
      match /customers/{customerId} {
        allow read: if isAppOwner() || isOwner(shopId) || isCustomerOwned(shopId) || canClaimCustomerByPhone();
        allow create: if isAppOwner() || isOwner(shopId) || isNewCustomerOwned(shopId);
        allow update: if isAppOwner() || isOwner(shopId) || ((isCustomerOwned(shopId) || canClaimCustomerByPhone()) && onlyChanged(['name','phone','phoneKey','customerUid','previousCustomerUid','securityUpgradedAt','updatedAt']));
        allow delete: if false;
      }
      match /purchaseRequests/{id} {
        allow read: if isAppOwner() || isOwner(shopId) || isCustomerOwned(shopId) || resourceCustomerMatchesLink(shopId);
        allow create: if isAppOwner() || isOwner(shopId) || (requestCustomerMatchesLink(shopId) && shopActive(shopId) && request.resource.data.status == 'pending_trader');
        allow update: if isAppOwner() || isOwner(shopId) || (resourceCustomerMatchesLink(shopId) && requestCustomerMatchesLink(shopId) && request.resource.data.status in ['pending_trader','cancelled'] && onlyChanged(['items','lines','itemCount','qtyCount','total','paymentType','note','status','editedBy','editedAt','updatedAt','updatedMs','editCount','customerAck','customerAckAt','customerNote','customerRejectedAt']));
        allow delete: if false;
      }
      match /paymentRequests/{id} {
        allow read: if isAppOwner() || isOwner(shopId) || isCustomerOwned(shopId);
        allow create: if isNewCustomerOwned(shopId);
        allow update: if isAppOwner() || isOwner(shopId);
        allow delete: if false;
      }
      match /returnRequests/{id} {
        allow read: if isAppOwner() || isOwner(shopId) || isCustomerOwned(shopId);
        allow create: if isNewCustomerOwned(shopId);
        allow update: if isAppOwner() || isOwner(shopId);
        allow delete: if false;
      }
      match /messages/{id} {
        allow read: if isAppOwner() || isOwner(shopId) || isCustomerOwned(shopId) || resource.data.customerId == '__app_owner__';
        allow create: if isAppOwner() || isOwner(shopId) || isNewCustomerOwned(shopId);
        allow update: if isAppOwner() || isOwner(shopId) || (isCustomerOwned(shopId) && onlyChanged(['readByCustomer','readAt','updatedAt']));
        allow delete: if false;
      }
      match /paymentSchedules/{id} {
        allow read: if isAppOwner() || isOwner(shopId) || isCustomerOwned(shopId);
        allow create, update: if isAppOwner() || isOwner(shopId);
        allow delete: if false;
      }
      match /invoices/{id} {
        allow read: if isAppOwner() || isOwner(shopId) || isCustomerOwned(shopId);
        allow create, update: if isAppOwner() || isOwner(shopId);
        allow delete: if false;
      }
      match /customerLedger/{id} {
        allow read: if isAppOwner() || isOwner(shopId) || isCustomerOwned(shopId);
        allow create, update: if isAppOwner() || isOwner(shopId);
        allow delete: if false;
      }
      match /stockLedger/{id} {
        allow read: if isAppOwner() || isOwner(shopId);
        allow create: if isAppOwner() || isOwner(shopId);
        allow update, delete: if false;
      }
      match /auditLogs/{id} {
        allow read: if isAppOwner() || isOwner(shopId);
        allow create: if isAppOwner() || isOwner(shopId);
        allow update, delete: if false;
      }
      match /ownerLogs/{id} {
        allow read, create: if isAppOwner();
        allow update, delete: if false;
      }
    }
  }
}
